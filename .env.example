# Database
POSTGRES_DB=bulk_email
POSTGRES_USER=bulk_email_user
POSTGRES_PASSWORD=changeme_strong_password_here
DATABASE_URL=postgresql://bulk_email_user:changeme_strong_password_here@postgres:5432/bulk_email

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=changeme_jwt_secret_at_least_32_chars_long
JWT_REFRESH_SECRET=changeme_refresh_secret_at_least_32_chars

# Admin (seeded on first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_admin_password

# Server
PORT=3001
NODE_ENV=development

# Client
VITE_API_URL=http://localhost:3001/api/v1

# Tracking
TRACKING_DOMAIN=https://track.yourdomain.com

# Gmail SMTP (configure in dashboard Settings)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# AWS SES (configure in dashboard Settings)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_EMAIL=
