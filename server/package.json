{
  "name": "bulk-email-server",
  "version": "1.0.0",
  "description": "Bulk Email Sender API Server",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:worker": "node dist/workers/index.js",
    "migrate:up": "node-pg-migrate up --migration-file-language ts --migrations-dir src/db/migrations",
    "migrate:down": "node-pg-migrate down --migration-file-language ts --migrations-dir src/db/migrations",
    "migrate:create": "node-pg-migrate create --migration-file-language ts --migrations-dir src/db/migrations",
    "seed": "ts-node src/db/seeds/001_admin-user.ts",
    "lint": "eslint src/",
    "test": "jest --config jest.config.js"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.500.0",
    "@aws-sdk/client-sns": "^3.500.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "handlebars": "^4.7.8",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-pg-migrate": "^7.0.0",
    "nodemailer": "^6.9.8",
    "pg": "^8.11.3",
    "rate-limiter-flexible": "^4.0.1",
    "uuid": "^9.0.0",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^6.4.14",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  }
}
